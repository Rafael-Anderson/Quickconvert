    "update-yt-dlp": "node scripts/update-yt-dlp.mjs"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "20.14.15",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.19",
    "tailwindcss": "^3.4.19",
    "typescript": "5.5.4"
  }
