# Copy to .env.production and fill in real values for the target VPS.
# Next.js loads this file automatically when NODE_ENV=production (set by
# pm2.config.cjs's env_production block). See README.md "Security &
# operational limits" for what each limit actually enforces.

# --- Binary locations ---
# Full path to the yt-dlp binary. Required unless yt-dlp is on the service
# account's PATH (it generally won't be — PM2 runs as a Windows service).
YT_DLP_PATH=C:\tools\yt-dlp.exe

# Folder containing ffmpeg.exe/ffprobe.exe (not the exe path itself).
FFMPEG_LOCATION=C:\tools\ffmpeg\bin

# Optional — only needed if aria2c is installed (see README.md).
# ARIA2C_PATH=C:\tools\aria2c.exe
# ARIA2C_CONNECTIONS=16

# Fragments yt-dlp downloads in parallel for segmented sources.
# YT_DLP_CONCURRENT_FRAGMENTS=8

# --- Resource limits ---
# Defaults below are tuned down from the app's own defaults (2048M / 3
# concurrent jobs) to fit a 1 vCore / 2GB RAM VPS, where a couple of
# simultaneous ffmpeg transcodes would exhaust the box. Raise these if
# deploying to larger hardware.
MAX_FILESIZE=1024M
MAX_DURATION_SECONDS=14400
MAX_CONCURRENT_JOBS=1
MAX_QUEUE_SIZE=5
MAX_CONCURRENT_JOBS_PER_IP=1

# --- Rate limiting ---
RATE_LIMIT_MAX_REQUESTS_PER_IP=10
RATE_LIMIT_WINDOW_MS=300000
